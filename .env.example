# Email (Resend)
RESEND_API_KEY=

# Notion CRM
NOTION_API_KEY=
# NGA Sessions Schedule DB — public class schedule fed into /schedule
NOTION_SESSIONS_DB_ID=
# NGA Drop-in Registrations DB — Stripe webhook writes a row per paid drop-in
NOTION_DROPINS_DB_ID=
# NGA Camp Roster DB — Friday-before-camp reminder cron syncs paid camp
# registrants here (read-model from Stripe) + uses the Reminder Sent checkbox
# for send-once idempotency. Optional — cron no-ops if unset.
NOTION_CAMP_ROSTER_DB_ID=
# NGA Waitlist DB — /api/waitlist writes a row per signup. Required fields:
#   Parent Name (title), Parent Email (email), Parent Phone (phone_number),
#   Preferred Area (select with values matching ALLOWED_AREAS in /api/waitlist),
#   Status (select: Active/Notified/Removed), Marketing Opt-In (checkbox).
NOTION_WAITLIST_DB_ID=
# NGA Newsletter Subscribers DB — /api/newsletter writes a row per signup.
# Dedups by Email (no duplicate welcome). Required fields:
#   Parent Name (title), Email (email), Child Age (number),
#   Status (select: Active/Unsubscribed), Marketing Opt-In (checkbox),
#   Welcome Sent (checkbox). If unset, the form still sends the welcome email;
#   only the subscriber-row write is skipped.
NOTION_NEWSLETTER_DB_ID=
# NGA Crew Polls DB — coach-owned candidate slots shared to WhatsApp. Required
# fields: Title (title), Slug (rich_text, unique), Status (select:
# Draft/Open/Closed/Confirmed/Cancelled), Day (rich_text), Start Time
# (rich_text), End Time (rich_text), Location (rich_text), Level (select:
# Red/Orange/Green/Yellow), Min Party Size (number), Coach Notes (rich_text).
NOTION_CREW_POLLS_DB_ID=
# NGA Poll Responses DB — one row per parent vote. Required fields: Parent
# Name (title), Parent Email (email), Parent Phone (phone_number), Poll
# (relation -> Crew Polls), Child First Name (rich_text), Child Birth Year
# (number), Child Level (select), Vote (select: Yes/Maybe/No), Note
# (rich_text).
NOTION_POLL_RESPONSES_DB_ID=
# NGA Crew Commits DB — one row per parent locked in for 4 weeks of auto-
# reservation. Required fields: Parent Name (title), Parent Email (email),
# Parent Phone (phone_number), Child First Name (rich_text), Crew ID
# (rich_text), Status (select: Active/Paused/Completed/Cancelled/CardFailed),
# Stripe Customer ID (rich_text), Stripe Payment Method ID (rich_text),
# Weeks Committed (number), Weeks Reserved (number), Last Charge At (date),
# Last Error (rich_text).
NOTION_CREW_COMMITS_DB_ID=
# NGA Youth Pickleball News DB — /api/cron/scrape-news writes one row per
# article (deduped by URL). Sam triages in Notion; the Thursday newsletter
# auto-includes rows with Status = Approved and then flips them to Used.
# Required fields: Title (title), URL (url), Source (rich_text), Summary
# (rich_text), Published (date), Status (select: New/Approved/Used/Rejected),
# Discovered At (date), Keyword Hits (rich_text). Optional — scraper logs +
# continues if unset.
NOTION_NEWS_DB_ID=

# NGA Newsletter Drafts DB — Coach-voice longform sections drafted from the
# Tuesday NGA News Radar by the Wednesday cloud drafter routine, queued for
# the Thursday parent newsletter. Each weekly row carries Status=Pending by
# default; Sam flips to Approved (or Skip) in Notion before Thu 6pm.
# Required fields: Week (title), Status (select: Pending/Approved/Skip),
# Source Radar (url), Drafted At (date), Section Count (number),
# Notes (rich_text). The cron reads the row's page body (Notion blocks) and
# converts to HTML for the email's "From Coach Sam" lead block. Optional —
# weekly newsletter just hides the lead block if unset.
NOTION_NEWSLETTER_DRAFTS_DB_ID=

# NGA Crew Interest DB — /api/crew-interest writes a row per submission.
# Used as the no-active-poll fallback: parents describe their preferred slot
# and Sam reviews in Notion to decide whether to spin up a new Crew Poll.
# Required fields: Submission (title), Parent Name (rich_text), Parent Email
# (email), Parent Phone (phone_number), Child First Name (rich_text), Child
# Birth Year (number), Child Level (select: Red/Orange/Green/Yellow),
# Preferred Days (multi_select: Mon..Sun), Preferred Time (rich_text),
# Preferred Location (rich_text), Friends Wanted (rich_text), Notes
# (rich_text), Status (select: New/Reviewed/Polled/Closed), Source (select:
# Newsletter/Web/Other), Marketing Opt-In (checkbox).
NOTION_CREW_INTEREST_DB_ID=
# Coach OS cohort pool — Crew interest is forwarded here (track=youth) so it's
# auto-matched + invoiced from the /cohorts dashboard. Both optional; if unset,
# the forward is a no-op and the Crew form behaves exactly as before.
COACH_OS_COHORT_INTAKE_URL=https://coach.sammorrispb.com/api/cohort-intake
COHORT_INTAKE_TOKEN=
# NGA League Interest DB — the demand-validation signal for the youth league
# (which divisions to open first). One row per /league interest submission.
# Properties: Submission (title), Parent Name (rich_text), Parent Email (email),
# Parent Phone (phone_number), Child First Name (rich_text), Child Birth Year
# (number), Preferred Band (select: 7U/10U/14U/16U), Child Level (select:
# Red/Orange/Green/Yellow), Notes (rich_text), Status (select: New/Reviewed/
# Closed), Source (select: Newsletter/Web/Other), Marketing Opt-In (checkbox).
# Optional — the endpoint logs + continues (welcome email + Open Brain) if unset.
NOTION_LEAGUE_INTEREST_DB_ID=
# Shared secret for /api/notion-session-webhook. Configure the Notion
# automation to send this in the `x-nga-webhook-secret` header when a new
# Sessions row is created so matching waitlist parents are notified.
NOTION_WEBHOOK_SECRET=

# Stripe (NGA acct_1SOoW57210nhTc4j)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for the single $40 NGA Drop-in product (set after running scripts/setup-stripe-product.mjs)
STRIPE_DROPIN_PRICE_ID=
# Summer Camp price IDs (NGA Stripe) — two flat SKUs: a single morning ($50) and
# the full Mon–Thu week ($150). Create both prices, then paste here.
# Until set, /api/checkout-camp returns 503 and the camp pages still render.
# Macaroni Kid discount: after setting these, run scripts/setup-mackid-promo.mjs
# to mint the MACKID promotion code (15% off, scoped to the camp product). The
# camp checkout already passes allow_promotion_codes:true so parents can enter it.
STRIPE_CAMP_DAY_PRICE_ID=
STRIPE_CAMP_WEEK_PRICE_ID=
# Youth League season price ID (NGA Stripe) — full-pay only for v1. Until set,
# /api/checkout-league returns 503 ("enrollment isn't open yet") and the public
# /league page still renders (it routes to the interest form, not checkout).
# Set this + swap the page CTA once the P0 launch gate clears to go live.
STRIPE_LEAGUE_SEASON_PRICE_ID=
# Deferred until after P0 (documented in docs/youth-pickleball-league-build-spec.md):
#   STRIPE_LEAGUE_DEPOSIT_PRICE_ID=   # deposit-then-balance option
#   STRIPE_LEAGUE_PLAN_PRICE_ID=      # installment payment-plan option
# Dark go-live flag for /league. "true" swaps the hero CTA + form card from the
# interest-capture form to the season ENROLLMENT form (LeagueSeasonForm). Unset/any
# other value keeps the page in interest mode (today's default). This is the UI
# guard; STRIPE_LEAGUE_SEASON_PRICE_ID is the separate charge guard. BOTH must be
# set — and ONLY after the P0 launch gate (permit/insurance/entity/vetting/waivers)
# clears — to take real season money. See the launch-readiness register.
NEXT_PUBLIC_LEAGUE_ENROLLMENT_OPEN=
# Public URL of the community-os league growth dashboard. Optional — when unset,
# the /league page hides the "Open the dashboard" card. Set once the app ships.
NEXT_PUBLIC_LEAGUE_APP_URL=

# Open Brain ingest
OPEN_BRAIN_INGEST_URL=
LEAD_INGEST_TOKEN=

# Open Brain analytics (used by /api/analytics proxy)
# Set in Vercel to:
#   https://lfazndedomuhgcssxkrx.supabase.co/functions/v1/analytics-ingest
OPEN_BRAIN_ANALYTICS_URL=

# Admin secret for POST /api/post-eval-followup, /api/eval-confirmation, and
# /api/eval-reengagement (Resend send + Notion read/update; ?secret=<value>)
NGA_ADMIN_SECRET=

# Dedicated Bearer secret for the agent-callable attendance check-in
# (POST /api/coach/attendance, Authorization: Bearer <value>). Fires the same
# fan-out as the coach toggle (Notion Attendance + Open Brain activity +
# player-profile recompute). Kept DISTINCT from NGA_ADMIN_SECRET to isolate
# blast radius on this minor-PII write. Unset = the route fails closed (401).
ATTENDANCE_SECRET=

# Dedicated Bearer secret for the agent-callable session ops (cancel +
# reschedule). The admin UI authorizes via the nga_admin cookie; an agent / cron
# sends Authorization: Bearer <value> to POST /api/admin/sessions/{cancel,
# reschedule}. Both hit the SAME route -> SAME engine, so the agent fires the
# identical trigger fan-out (refunds/comms/Notion writes) the editor does
# (pinned by invariant-admin-session-ops-parity.spec.ts). DISTINCT from
# NGA_ADMIN_SECRET to isolate this refund-capable surface. Unset = Bearer path
# fails closed (the cookie path still works for the UI).
SESSION_OPS_SECRET=

# Dedicated Bearer secret for the agent-callable crew confirmation
# (POST /api/coach/crew-confirm, Authorization: Bearer <value>). Fires the same
# fan-out as the coach ConfirmCrewForm (per-parent crew-confirmed email + poll
# Status -> Confirmed). Kept DISTINCT from NGA_ADMIN_SECRET to isolate blast
# radius on this minor-PII fan-out. Unset = the route fails closed (401).
CREW_CONFIRM_SECRET=

# --- /admin area (Sessions editor) sign-in ---
# Email allowlist for /admin. Comma-separated, case-insensitive. Only these
# emails can request a magic link and reach /admin/sessions. Empty = deny all.
ADMIN_ALLOWLIST=sam.morris2131@gmail.com,nextgenacademypb@gmail.com
# HMAC signing key for /admin magic-link tokens + session cookies. SHARED with
# the /coach area (one secret, scoped per-area in the payload). Required for
# admin sign-in. Rotating it invalidates all coach + admin sessions.
COACH_SIGNING_SECRET=
# NGA_ADMIN_PASSWORD — DEPRECATED. The /admin password gate was replaced by the
# email magic-link flow above; this var is no longer read. Safe to remove.

# Signing key for one-click newsletter unsubscribe links (HMAC). Optional —
# falls back to NGA_ADMIN_SECRET if unset; verify accepts BOTH this and the
# legacy NGA_ADMIN_SECRET, so unsubscribe links in every past issue keep
# working when this is introduced (CAN-SPAM).
NEWSLETTER_UNSUB_SECRET=

# Signing key for referral ?ref=<token> links on /newsletter (HMAC). Optional
# — same fallback + dual-verify pattern, so old forwarded-email links keep
# attributing. Distinct from NEWSLETTER_UNSUB_SECRET so referral and
# unsubscribe tokens can't be replayed across each other (different HMAC
# payload prefix).
REFERRAL_TOKEN_SECRET=

# Signing key for /commit/<token> 4-week-commit deep links (HMAC). Optional —
# falls back to NGA_ADMIN_SECRET if unset; verify accepts BOTH this and the
# legacy NGA_ADMIN_SECRET, so setting it never bricks links already in parent
# inboxes. Set independently to shrink the admin secret's blast radius.
COMMIT_TOKEN_SECRET=

# Signing key for parent self-serve cancel links (HMAC, non-expiring).
# Optional — same fallback + dual-verify pattern as COMMIT_TOKEN_SECRET.
# Rotate THIS to invalidate new-era cancel links; legacy-era links die only
# when NGA_ADMIN_SECRET rotates.
CANCEL_TOKEN_SECRET=

# Signing key for coach session-wide cancel links in pre-event briefing emails
# (HMAC). Optional — same fallback + dual-verify pattern.
SESSION_CANCEL_TOKEN_SECRET=

# Twilio (NGA SMS — booking confirmation, 24h reminder, session-cancel broadcast).
# All three required; if any missing, sendSms() returns { ok:false, skipped:'not_configured' }.
# Pending 10DLC registration clearance — leave blank until A2P brand+campaign approved.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Vercel cron auth — Authorization: Bearer $CRON_SECRET on /api/cron/*.
# Vercel auto-injects this when invoking the scheduled job; manual curl needs
# the same header. Independent of NGA_ADMIN_SECRET (which gates admin endpoints).
CRON_SECRET=

# Cluster season registration (ships dark — see src/data/cluster-launch-gates.ts)
# Stripe price for the cluster season fee. Unset = checkout returns 503.
STRIPE_CLUSTER_SEASON_PRICE_ID=
# Cluster Registrations Notion DB (roster + webhook idempotency key). Create
# the DB and set this BEFORE flipping any launch gate.
NOTION_CLUSTER_REGS_DB_ID=

# NGA Processed Stripe Events DB — shared webhook-idempotency ledger for camp +
# league (which have no roster row of their own). One row per handled
# checkout-session id; the handler records it before its parent/admin emails so
# a Stripe redelivery no-ops instead of resending. Required fields: Stripe
# Session ID (title), Kind (select: camp/league), Processed At (date). Unset =
# camp/league behave exactly as today (emails fire, no dedupe) — inert until set.
NOTION_PROCESSED_EVENTS_DB_ID=
