# Email (Resend)
RESEND_API_KEY=

# Notion CRM
NOTION_API_KEY=
# NGA Sessions Schedule DB — public class schedule fed into /schedule
NOTION_SESSIONS_DB_ID=
# NGA Drop-in Registrations DB — Stripe webhook writes a row per paid drop-in
NOTION_DROPINS_DB_ID=
# NGA Waitlist DB — /api/waitlist writes a row per signup. Required fields:
#   Parent Name (title), Parent Email (email), Parent Phone (phone_number),
#   Preferred Area (select with values matching ALLOWED_AREAS in /api/waitlist),
#   Status (select: Active/Notified/Removed), Marketing Opt-In (checkbox).
NOTION_WAITLIST_DB_ID=
# NGA Newsletter Subscribers DB — /api/newsletter writes a row per signup.
# Dedups by Email (no duplicate welcome). Required fields:
#   Parent Name (title), Email (email), Child Age (number),
#   Status (select: Active/Unsubscribed), Marketing Opt-In (checkbox),
#   Welcome Sent (checkbox). If unset, the form still sends the welcome email;
#   only the subscriber-row write is skipped.
NOTION_NEWSLETTER_DB_ID=
# NGA Crew Polls DB — coach-owned candidate slots shared to WhatsApp. Required
# fields: Title (title), Slug (rich_text, unique), Status (select:
# Draft/Open/Closed/Confirmed/Cancelled), Day (rich_text), Start Time
# (rich_text), End Time (rich_text), Location (rich_text), Level (select:
# Red/Orange/Green/Yellow), Min Party Size (number), Coach Notes (rich_text).
NOTION_CREW_POLLS_DB_ID=
# NGA Poll Responses DB — one row per parent vote. Required fields: Parent
# Name (title), Parent Email (email), Parent Phone (phone_number), Poll
# (relation -> Crew Polls), Child First Name (rich_text), Child Birth Year
# (number), Child Level (select), Vote (select: Yes/Maybe/No), Note
# (rich_text).
NOTION_POLL_RESPONSES_DB_ID=
# NGA Crew Commits DB — one row per parent locked in for 4 weeks of auto-
# reservation. Required fields: Parent Name (title), Parent Email (email),
# Parent Phone (phone_number), Child First Name (rich_text), Crew ID
# (rich_text), Status (select: Active/Paused/Completed/Cancelled/CardFailed),
# Stripe Customer ID (rich_text), Stripe Payment Method ID (rich_text),
# Weeks Committed (number), Weeks Reserved (number), Last Charge At (date),
# Last Error (rich_text).
NOTION_CREW_COMMITS_DB_ID=
# Shared secret for /api/notion-session-webhook. Configure the Notion
# automation to send this in the `x-nga-webhook-secret` header when a new
# Sessions row is created so matching waitlist parents are notified.
NOTION_WEBHOOK_SECRET=

# Stripe (NGA acct_1SOoW57210nhTc4j)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for the single $40 NGA Drop-in product (set after running scripts/setup-stripe-product.mjs)
STRIPE_DROPIN_PRICE_ID=

# Open Brain ingest
OPEN_BRAIN_INGEST_URL=
LEAD_INGEST_TOKEN=

# Open Brain analytics (used by /api/analytics proxy)
# Set in Vercel to:
#   https://lfazndedomuhgcssxkrx.supabase.co/functions/v1/analytics-ingest
OPEN_BRAIN_ANALYTICS_URL=

# Admin secret for POST /api/post-eval-followup, /api/eval-confirmation, and
# /api/eval-reengagement (Resend send + Notion read/update; ?secret=<value>)
NGA_ADMIN_SECRET=

# Signing key for one-click newsletter unsubscribe links (HMAC). Optional —
# falls back to NGA_ADMIN_SECRET if unset, so the weekly newsletter works
# without provisioning this. Set it only to rotate unsubscribe links
# independently of the admin secret.
NEWSLETTER_UNSUB_SECRET=

# Signing key for /commit/<token> 4-week-commit deep links (HMAC). Optional —
# falls back to NGA_ADMIN_SECRET if unset. Set independently if you ever need
# to invalidate outstanding commit links without rotating the admin secret.
COMMIT_TOKEN_SECRET=

# Twilio (NGA SMS — booking confirmation, 24h reminder, session-cancel broadcast).
# All three required; if any missing, sendSms() returns { ok:false, skipped:'not_configured' }.
# Pending 10DLC registration clearance — leave blank until A2P brand+campaign approved.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Vercel cron auth — Authorization: Bearer $CRON_SECRET on /api/cron/*.
# Vercel auto-injects this when invoking the scheduled job; manual curl needs
# the same header. Independent of NGA_ADMIN_SECRET (which gates admin endpoints).
CRON_SECRET=
